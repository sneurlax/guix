# Pinned Flutter SDK version for reproducible builds.
# Update this file when upgrading Flutter.
# Run `scripts/fetch-flutter.sh` after changing.
FLUTTER_VERSION="3.24.5"
FLUTTER_CHANNEL="stable"

# SHA-256 hashes per architecture.
# Get hashes from: https://docs.flutter.dev/release/archive
# Or run fetch-flutter.sh once — it prints the computed hash.
FLUTTER_SHA256_X64=""
FLUTTER_SHA256_ARM64=""
