# Pinned Android SDK component versions for reproducible builds.
# Update this file when upgrading the Android toolchain.
# Run `scripts/fetch-android-sdk.sh` after changing.

# Google cmdline-tools archive (used to bootstrap sdkmanager).
# Get build numbers from: https://developer.android.com/studio#command-tools
ANDROID_CMDLINE_TOOLS_BUILD="14742923"
ANDROID_CMDLINE_TOOLS_SHA256=""

# SDK components installed via sdkmanager.
# These match Flutter 3.24.5 defaults.
ANDROID_PLATFORM_VERSION="android-34"
ANDROID_BUILD_TOOLS_VERSION="34.0.0"
ANDROID_NDK_VERSION="23.1.7779620"
